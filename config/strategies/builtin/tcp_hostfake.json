{
  "id": "tcp_hostfake",
  "name": "HostFake — подмена SNI в fake-пакетах",
  "description": "Использует hostfakesplit: подменяет домен в fake-пакете, обходит SNI-based DPI",
  "type": "combined",
  "version": 1,
  "profiles": [
    {
      "id": "http80",
      "name": "HTTP (порт 80)",
      "enabled": true,
      "args": "--filter-tcp=80 --filter-l7=http --payload=http_req --lua-desync=fake:blob=fake_default_http:tcp_md5:repeats=3 --lua-desync=hostfakesplit:nofake1:midhost=midsld:tcp_md5"
    },
    {
      "id": "tls443",
      "name": "TLS (порт 443)",
      "enabled": true,
      "args": "--filter-tcp=443 --filter-l7=tls --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:repeats=3 --lua-desync=hostfakesplit:nofake1:midhost=midsld:tcp_md5"
    },
    {
      "id": "quic443",
      "name": "QUIC/UDP (порт 443)",
      "enabled": true,
      "args": "--filter-udp=443 --filter-l7=quic --payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=6"
    }
  ]
}
