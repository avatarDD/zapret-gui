{
  "id": "tcp_alt2",
  "name": "Alt 2 — multidisorder + tcp_seq offset",
  "description": "fake с tcp_md5 и смещением sequence number, multidisorder вместо multisplit",
  "type": "combined",
  "version": 1,
  "profiles": [
    {
      "id": "http80",
      "name": "HTTP (порт 80)",
      "enabled": true,
      "args": "--filter-tcp=80 --filter-l7=http --payload=http_req --lua-desync=fake:blob=fake_default_http:tcp_md5 --lua-desync=multidisorder:pos=method+2"
    },
    {
      "id": "tls443",
      "name": "TLS (порт 443)",
      "enabled": true,
      "args": "--filter-tcp=443 --filter-l7=tls --payload=tls_client_hello --lua-desync=fake:blob=fake_default_tls:tcp_md5:tcp_seq=-10000 --lua-desync=multidisorder:pos=1,midsld"
    },
    {
      "id": "quic443",
      "name": "QUIC/UDP (порт 443)",
      "enabled": true,
      "args": "--filter-udp=443 --filter-l7=quic --payload=quic_initial --lua-desync=fake:blob=fake_default_quic:repeats=6"
    }
  ]
}
