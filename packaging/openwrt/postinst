#!/bin/sh
# postinst — post-install для zapret-gui (OpenWrt)

set -e

APP_DIR="/usr/share/zapret-gui"
CONFIG_DIR="/etc/zapret-gui"

echo "Zapret Web-GUI — установка (OpenWrt)"

# Создаём директории
mkdir -p "$CONFIG_DIR" 2>/dev/null || true
mkdir -p "$APP_DIR/config/strategies/user" 2>/dev/null || true
mkdir -p "$APP_DIR/init.d" 2>/dev/null || true
mkdir -p "$APP_DIR/lists" 2>/dev/null || true
mkdir -p /tmp/zapret-gui 2>/dev/null || true

# Права
chmod 755 "$APP_DIR/app.py" 2>/dev/null || true

# Включаем автозапуск
/etc/init.d/zapret-gui enable 2>/dev/null || true

# Проверяем и устанавливаем bottle
if ! python3 -c "import bottle" 2>/dev/null; then
    echo "  Установка bottle (python3-bottle недоступен в opkg)..."
    if python3 -m pip install bottle --quiet 2>/dev/null; then
        echo "  ✓ bottle установлен через pip"
    else
        SITE=$(python3 -c "import site; print(site.getsitepackages()[0])" 2>/dev/null) || true
        if [ -z "$SITE" ]; then
            SITE=$(python3 -c "import site; print(site.getusersitepackages())" 2>/dev/null) || true
        fi
        if [ -n "$SITE" ] && mkdir -p "$SITE" 2>/dev/null && \
           wget -q -O "$SITE/bottle.py" \
               "https://raw.githubusercontent.com/bottlepy/bottle/master/bottle.py" 2>/dev/null; then
            echo "  ✓ bottle.py загружен в $SITE"
        else
            echo "  ⚠ Установите вручную: python3 -m pip install bottle"
        fi
    fi
fi

echo ""
echo "  ✓ Установлено в $APP_DIR"
echo "  Запуск: /etc/init.d/zapret-gui start"
echo "  Веб-интерфейс: http://<IP роутера>:8080"
echo ""

exit 0
