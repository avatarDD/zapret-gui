#!/bin/sh
# prerm — pre-remove для zapret-gui (OpenWrt)

echo "Zapret Web-GUI — удаление..."

# Остановить и отключить
/etc/init.d/zapret-gui stop 2>/dev/null || true
/etc/init.d/zapret-gui disable 2>/dev/null || true

# Снять runtime-артефакты: nfqws2, firewall-правила, hotplug-хук — до
# удаления файлов приложения.
APP_DIR="/usr/share/zapret-gui"
if [ -f "$APP_DIR/app.py" ] && command -v python3 >/dev/null 2>&1; then
    PYTHONPATH="$APP_DIR" python3 -m core.teardown 2>/dev/null || true
fi
rm -f /etc/hotplug.d/firewall/90-zapret-gui 2>/dev/null || true
rm -f /opt/etc/ndm/netfilter.d/100-zapret-gui.sh 2>/dev/null || true
echo "  ✓ Firewall-правила и хуки сняты"

# Очистить кеш Python
find /usr/share/zapret-gui -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true

echo "  ✓ Конфигурация сохранена в /etc/zapret-gui/"
echo "  ✓ Удаление завершено"

exit 0
